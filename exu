    <script>
        // Variáveis globais
        let selectedPackage = null;
        let selectedPrice = 0;
        let basePrice = 0;
        
        // Timer de urgência
        let timeLeft = 900; // 15 minutos em segundos
        const timerElement = document.getElementById('timer');
        
        function updateTimer() {
            if (timeLeft <= 0) {
                timerElement.innerHTML = "00:00";
                return;
            }
            
            timeLeft--;
            const minutes = Math.floor(timeLeft / 60);
            const seconds = timeLeft % 60;
            timerElement.innerHTML = `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
        }
        
        setInterval(updateTimer, 1000);

        // Função para abrir prévia dos vídeos
        function openPreview(videoUrl) {
            const modal = document.getElementById('previewModal');
            const video = document.getElementById('previewVideo');
            video.src = videoUrl;
            modal.classList.add('active');
            video.play();
        }

        function closePreview() {
            const modal = document.getElementById('previewModal');
            const video = document.getElementById('previewVideo');
            video.pause();
            video.src = '';
            modal.classList.remove('active');
        }

        // Função para selecionar pacote
        function selectPackage(pkg, price) {
            selectedPackage = pkg;
            selectedPrice = price;
            basePrice = price;
            
            // Remove seleção anterior
            document.querySelectorAll('.btn-select').forEach(btn => {
                btn.classList.remove('selected');
                btn.innerHTML = 'SELECIONAR';
            });
            
            // Marca o selecionado
            event.target.classList.add('selected');
            event.target.innerHTML = '✓ SELECIONADO';
            
            // Atualiza nomes
            let packageName = '';
            if (pkg === 'basico') packageName = 'BÁSICO';
            if (pkg === 'vip') packageName = 'VIP';
            if (pkg === 'premium') packageName = 'PREMIUM';
            
            document.getElementById('selectedPackageName').innerHTML = packageName;
            document.getElementById('selectedPackagePrice').innerHTML = `R$ ${price},00`;
            
            // Habilita botão de checkout
            document.getElementById('checkoutBtn').disabled = false;
            document.getElementById('selectedPackageInfo').innerHTML = `Pacote ${packageName} selecionado - R$ ${price},00`;
            
            updateTotal();
        }

        // Função para abrir checkout
        function openCheckout() {
            if (!selectedPackage) {
                alert('Selecione um pacote primeiro, seu animal!');
                return;
            }
            document.getElementById('checkoutModal').classList.add('active');
        }

        function closeCheckout() {
            document.getElementById('checkoutModal').classList.remove('active');
        }

        // Função para atualizar total com upsells
        function updateTotal() {
            let total = basePrice;
            
            if (document.getElementById('upsell1').checked) total += 20;
            if (document.getElementById('upsell2').checked) total += 30;
            if (document.getElementById('upsell3').checked) total += 50;
            
            document.getElementById('totalPrice').innerHTML = `R$ ${total},00`;
        }

        // Função de pagamento (aqui você integra com o gateway)
        function processPayment() {
            const total = document.getElementById('totalPrice').innerHTML;
            
            // PEGA OS UPSELLS SELECIONADOS
            const upsells = [];
            if (document.getElementById('upsell1').checked) upsells.push('Área VIP');
            if (document.getElementById('upsell2').checked) upsells.push('Downloads');
            if (document.getElementById('upsell3').checked) upsells.push('Conteúdos Exclusivos');
            
            const paymentData = {
                package: selectedPackage,
                basePrice: basePrice,
                totalValue: total,
                upsells: upsells,
                timestamp: new Date().toISOString()
            };
            
            console.log('Dados do pagamento:', paymentData);
            
            // AQUI VOCÊ CHAMA O TEU GATEWAY BLACK
            // Exemplo de chamada pro gateway:
            /*
            fetch('https://api-gateway.techbynet.com/api/user/transactions', {
                method: 'POST',
                headers: {
                    'x-api-key': 'sua_chave_aqui',
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    amount: parseInt(total.replace('R$', '').replace(',', '')) * 100,
                    paymentMethod: "PIX",
                    customer: {
                        name: "Cliente VIP",
                        email: "cliente@email.com",
                        document: {"number": gerarCPF(), "type": "CPF"},
                    },
                    items: [{
                        title: `Pacote ${selectedPackage} + Upsells`,
                        unitPrice: parseInt(total.replace('R$', '').replace(',', '')) * 100,
                        quantity: 1
                    }]
                })
            })
            */
            
            alert(`💰 PAGAMENTO PROCESSADO!\n\nTotal: ${total}\nPacote: ${selectedPackage}\nUpsells: ${upsells.length > 0 ? upsells.join(', ') : 'Nenhum'}\n\nAgora é só aguardar a confirmação!`);
            
            closeCheckout();
        }

        // Função pra gerar CPF (caso precise)
        function gerarCPF() {
            let cpf = [];
            for (let i = 0; i < 9; i++) {
                cpf.push(Math.floor(Math.random() * 9) + 1);
            }
            
            let soma = 0;
            for (let i = 0; i < 9; i++) {
                soma += cpf[i] * (10 - i);
            }
            let dig1 = 11 - (soma % 11);
            dig1 = dig1 >= 10 ? 0 : dig1;
            
            soma = 0;
            for (let i = 0; i < 10; i++) {
                soma += (i < 9 ? cpf[i] : dig1) * (11 - i);
            }
            let dig2 = 11 - (soma % 11);
            dig2 = dig2 >= 10 ? 0 : dig2;
            
            cpf.push(dig1);
            cpf.push(dig2);
            
            return cpf.join('');
        }

        // Inicializa os vídeos
        window.onload = function() {
            // Pré-carrega os vídeos (opcional)
            const videos = document.querySelectorAll('.video-player');
            videos.forEach(video => {
                video.addEventListener('mouseenter', function() {
                    this.play();
                });
                video.addEventListener('mouseleave', function() {
                    this.pause();
                    this.currentTime = 0;
                });
            });
        };
    </script>
</body>
</html>

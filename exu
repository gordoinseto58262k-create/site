            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 100%);
            color: #fff;
            min-height: 100vh;
        }

        /* HEADER */
        .header {
            padding: 20px;
            text-align: center;
            border-bottom: 1px solid #ff3366;
            background: rgba(0,0,0,0.5);
        }

        .logo {
            font-size: 32px;
            font-weight: 800;
            background: linear-gradient(45deg, #ff3366, #ff6b6b);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: 2px;
        }

        .age-warning {
            position: absolute;
            top: 20px;
            right: 20px;
            background: #ff3366;
            color: white;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 14px;
            font-weight: 600;
        }

        /* CONTAINER PRINCIPAL */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        /* HERO SECTION */
        .hero {
            text-align: center;
            margin-bottom: 50px;
        }

        h1 {
            font-size: 48px;
            margin-bottom: 20px;
            background: linear-gradient(45deg, #fff, #ff3366);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .subtitle {
            font-size: 20px;
            color: #ccc;
            margin-bottom: 30px;
        }

        /* CONTADOR REGRESSIVO */
        .countdown {
            background: rgba(255,51,102,0.2);
            border: 2px solid #ff3366;
            border-radius: 50px;
            padding: 20px;
            max-width: 400px;
            margin: 30px auto;
            text-align: center;
        }

        .countdown h3 {
            color: #ff3366;
            margin-bottom: 10px;
        }

        .timer {
            font-size: 36px;
            font-weight: 800;
            color: #fff;
        }

        /* GRID DE VÍDEOS - AS PRÉVIAS QUE TU PEDIU */
